# 忽略 prompt 文件夹
prompt/

# 忽略虚拟环境目录
.venv/
venv/
env/

# 忽略编译生成的文件和目录
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# 忽略构建目录
build/
dist/

# 忽略日志文件
*.log

# 忽略配置文件（除了需要版本控制的）
config.json

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略测试生成的数据库文件
test_*.db
*.db-journal

# 忽略运行时数据目录
.stock_monitor/
/cache/
# 确保源码中的 cache 包不被忽略
!stock_monitor/core/cache/

# 忽略 IDE 相关文件
.vscode/
.idea/
.lingma/

# 忽略临时文件
*.tmp
*.temp
chat.md

# 忽略开发配置和缓存
.stock_monitor_dev/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.env
.coverage
htmlcov/
pre_commit_output.txt
sha256.txt
*.bak

# 忽略打包产物
*.spec
!stock_monitor.spec
*.zip
*.exe

# 忽略特定的报告和分析文件
docs/clean_code_review.md
开机启动分析报告.md
项目分析报告.md
代码审查报告.md

# 忽略运行时生成的日志和数据
logs/
stock_monitor/logs/
stock_monitor/cache/
stock_monitor/.stock_monitor/
!stock_monitor/.stock_monitor/config.json.example

# Agent 相关
.agent/
.agents/
.agents/skills/
.agent/skills/
.agent/workflows/stock.md
skills-lock.json

# 其他工具
.continue/
